<!doctype html>
<html lang="en">
  <!-- Security rationale: the challenge view proves the session was stopped
       before authorization and explains the decision to operators/demo judges. -->
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>ATO Challenge Triggered</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar bg-white brand-bar">
      <div class="container">
        <span class="navbar-brand d-flex align-items-center gap-2 fw-bold">
          <span class="brand-mark">BoB</span>
          TrustPulse: ATO-Shield
        </span>
      </div>
    </nav>

    <main class="container py-5">
      <div class="challenge-panel bg-white p-4 p-md-5">
        <div class="threat-banner mb-4">
          <strong>Threat Prevented</strong>
          <span>ATO-Shield stopped this valid-password login before a banking session was created.</span>
        </div>
        <div class="row g-5">
          <section class="col-lg-6">
            <div class="security-kicker">Step-up verification required</div>
            <h1 class="h2 fw-bold mb-3">High Risk Login Detected</h1>
            <p class="muted-copy">The supplied password was correct, but the login context did not match the customer assurance profile. TrustPulse blocked the session and requested additional verification before access can continue.</p>

            <% if (error) { %>
              <div class="alert alert-danger mt-3"><%= error %></div>
            <% } %>

            <div class="incident-strip mt-4">
              <div>
                <span>Decision</span>
                <strong>CHALLENGED</strong>
              </div>
              <div>
                <span>Session</span>
                <strong>NOT CREATED</strong>
              </div>
              <div>
                <span>Threshold</span>
                <strong><%= threshold %></strong>
              </div>
            </div>

            <h2 class="h5 fw-bold mt-4">Explainability Reasons</h2>
            <% log.riskReasons.forEach(function(reason) { %>
              <div class="reason-row">
                <div>
                  <strong><%= reason.label %></strong>
                  <div class="muted-copy small"><%= reason.detail %></div>
                </div>
                <span class="reason-points">+<%= reason.points %></span>
              </div>
            <% }) %>

            <div class="operator-note mt-4">
              <strong>SOC Action</strong>
              <span>Mark as prevented ATO, notify the customer through the verified channel, and keep authorization denied until the step-up flow succeeds.</span>
            </div>

            <form class="otp-simulation mt-3" method="post" action="/challenge/verify">
              <strong>Step-up Verification</strong>
              <span>Enter the one-time code delivered to the registered channel ending in 42.</span>
              <div class="row g-2 align-items-center mt-1">
                <div class="col-sm-8">
                  <input class="form-control form-control-lg" name="verificationCode" inputmode="numeric" autocomplete="one-time-code" placeholder="6-digit code" required>
                </div>
                <div class="col-sm-4 d-grid">
                  <button class="btn btn-bob btn-lg" type="submit">Approve Session</button>
                </div>
              </div>
              <small class="text-muted">This step-up approval enrolls the browser and network as trusted after successful verification.</small>
            </form>
          </section>

          <section class="col-lg-5 offset-lg-1">
            <h2 class="h5 fw-bold mb-3">Threat Replay</h2>
            <div class="mb-3 text-muted"><%= formatTime(log.timestamp) %></div>
            <% log.replayEvents.forEach(function(event, index) { %>
              <div class="timeline-step">
                <span><%= index + 1 %></span>
                <strong><%= event %></strong>
              </div>
            <% }) %>
            <div class="risk-meter mt-4">
              <div class="d-flex justify-content-between mb-2">
                <strong>Internal Risk Score</strong>
                <strong><%= log.riskScore %> / 105</strong>
              </div>
              <div class="risk-track">
                <div class="risk-fill" style="width: <%= Math.min(log.riskScore, 105) / 105 * 100 %>%"></div>
              </div>
            </div>
            <a class="btn btn-bob mt-4" href="/">Review Next Login</a>
          </section>
        </div>
      </div>
    </main>
  </body>
</html>
