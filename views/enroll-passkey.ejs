<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Enroll Fingerprint – TrustPulse: ATO-Shield</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
    <style>
      body { background: #0a0f1e; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
      .enroll-card {
        background: rgba(255,255,255,0.04);
        border: 1px solid rgba(255,255,255,0.10);
        border-radius: 20px;
        padding: 3rem 2.5rem;
        max-width: 440px;
        width: 100%;
        text-align: center;
        box-shadow: 0 32px 80px rgba(0,0,0,0.5);
      }
      .fingerprint-icon {
        width: 80px; height: 80px;
        background: linear-gradient(135deg, #f37321, #c85a00);
        border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 2.2rem;
        animation: pulse 2s infinite;
      }
      @keyframes pulse {
        0%, 100% { box-shadow: 0 0 0 0 rgba(243,115,33,0.4); }
        50% { box-shadow: 0 0 0 16px rgba(243,115,33,0); }
      }
      .enroll-title { color: #fff; font-weight: 700; font-size: 1.5rem; margin-bottom: .5rem; }
      .enroll-sub { color: rgba(255,255,255,0.55); font-size: .9rem; margin-bottom: 2rem; line-height: 1.6; }
      .btn-enroll {
        background: linear-gradient(135deg, #f37321, #c85a00);
        border: none; color: #fff; font-weight: 600;
        padding: .85rem 2rem; border-radius: 12px;
        width: 100%; font-size: 1.05rem;
        transition: transform .15s, box-shadow .15s;
      }
      .btn-enroll:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(243,115,33,0.4); color: #fff; }
      .status-msg { min-height: 1.6rem; margin-top: 1rem; font-size: .9rem; font-weight: 600; }
      .steps { text-align: left; background: rgba(255,255,255,0.04); border-radius: 12px; padding: 1rem 1.2rem; margin-bottom: 1.5rem; }
      .steps li { color: rgba(255,255,255,0.7); font-size: .85rem; margin-bottom: .4rem; }
      .steps li::marker { color: #f37321; }
      .skip-link { display: block; margin-top: 1.2rem; color: rgba(255,255,255,0.3); font-size: .8rem; text-decoration: none; }
      .skip-link:hover { color: rgba(255,255,255,0.5); }
    </style>
  </head>
  <body>
    <div class="enroll-card">
      <div class="fingerprint-icon">🔐</div>
      <div class="enroll-title">Set Up Your Fingerprint</div>
      <div class="enroll-sub">
        You're logged in. To keep your account secure on this device, please enroll your fingerprint or passkey now. You'll use it for all future logins — no password needed.
      </div>

      <ol class="steps">
        <li>Click "Enroll Fingerprint" below</li>
        <li>Follow your device's biometric prompt (Touch ID, Windows Hello, Face ID, etc.)</li>
        <li>Done — future logins are instant and passwordless</li>
      </ol>

      <button class="btn btn-enroll" id="enrollBtn" type="button">
        🔐 Enroll Fingerprint / Passkey
      </button>
      <div class="status-msg" id="statusMsg"></div>

      <a href="/portal" class="skip-link" id="skipLink" style="display:none;">
        Skip for now (not recommended)
      </a>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      function toBase64Url(buffer) {
        const bytes = new Uint8Array(buffer);
        let binary = '';
        for (let i = 0; i < bytes.length; i++) binary += String.fromCharCode(bytes[i]);
        return btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/g, '');
      }

      function fromBase64Url(value) {
        const normalized = value.replace(/-/g, '+').replace(/_/g, '/');
        const padded = normalized + '==='.slice((normalized.length + 3) % 4);
        const binary = atob(padded);
        const bytes = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) bytes[i] = binary.charCodeAt(i);
        return bytes;
      }

      document.getElementById('enrollBtn').addEventListener('click', async function() {
        const btn = this;
        const status = document.getElementById('statusMsg');
        btn.disabled = true;
        btn.textContent = 'Waiting for your device...';
        status.style.color = '#aaa';
        status.textContent = 'Follow your device\'s biometric prompt...';

        try {
          const optRes = await fetch('/api/passkeys/registration/options', { credentials: 'same-origin' });
          if (!optRes.ok) throw new Error(await optRes.text());
          const options = await optRes.json();

          const credential = await navigator.credentials.create({
            publicKey: {
              ...options,
              challenge: fromBase64Url(options.challenge),
              user: { ...options.user, id: fromBase64Url(options.user.id) },
              excludeCredentials: (options.excludeCredentials || []).map(c => ({
                ...c, id: fromBase64Url(c.id)
              }))
            }
          });

          const response = credential.response;
          const verRes = await fetch('/api/passkeys/registration/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({
              id: credential.id,
              rawId: toBase64Url(credential.rawId),
              type: credential.type,
              response: {
                clientDataJSON: toBase64Url(response.clientDataJSON),
                attestationObject: toBase64Url(response.attestationObject),
                transports: response.getTransports ? response.getTransports() : []
              }
            })
          });

          const result = await verRes.json();
          if (!verRes.ok || !result.verified) throw new Error(result.error || 'Enrollment failed');

          status.style.color = '#4ade80';
          status.textContent = '✅ Fingerprint enrolled! Redirecting to your portal...';
          btn.textContent = '✅ Enrolled!';
          setTimeout(() => { window.location.href = '/portal'; }, 1200);

        } catch (err) {
          status.style.color = '#f87171';
          status.textContent = '❌ ' + (err.message || 'Enrollment failed. Please try again.');
          btn.disabled = false;
          btn.textContent = '🔐 Enroll Fingerprint / Passkey';
          // Show skip link after a failure so user isn't permanently locked
          document.getElementById('skipLink').style.display = 'block';
        }
      });
    </script>
  </body>
</html>
