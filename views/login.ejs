<!doctype html>
<html lang="en">
  <!-- Security rationale: this page demonstrates that credentials alone do not
       authorize a banking session; context is collected for post-password risk. -->
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>TrustPulse: ATO-Shield</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
  </head>
  <body class="login-shell">
    <nav class="navbar navbar-expand-lg login-nav">
      <div class="container">
        <span class="navbar-brand text-white d-flex align-items-center gap-2 fw-bold">
          <span class="brand-mark">BoB</span>
          TrustPulse: ATO-Shield
        </span>
        <div class="d-flex gap-2">
          <a class="btn btn-sm btn-outline-light" href="#architecture">Controls</a>
          <a class="btn btn-sm btn-bob" href="/admin">SOC Portal</a>
        </div>
      </div>
    </nav>

    <main>
      <section class="container hero-grid py-4 py-lg-5">
        <div class="row align-items-center g-4 g-xl-5">
          <section class="col-lg-7">
            <div class="security-kicker">Bank-grade identity assurance</div>
            <h1 class="hero-title mb-3">Detect Account Takeovers before a banking session is created.</h1>
            <p class="hero-copy mb-4">TrustPulse evaluates contextual identity trust after password success, combining device fingerprinting, session timing, browser integrity, and risk explainability before a session is created.</p>

            <div class="row g-3">
              <div class="col-md-4">
                <div class="proof-tile">
                  <span>Decision Point</span>
                  <strong>Pre-Session</strong>
                </div>
              </div>
              <div class="col-md-4">
                <div class="proof-tile">
                  <span>Risk Threshold</span>
                  <strong>65 / 105</strong>
                </div>
              </div>
              <div class="col-md-4">
                <div class="proof-tile">
                  <span>Decision Model</span>
                  <strong>Explainable</strong>
                </div>
              </div>
            </div>
          </section>

          <section class="col-lg-5">
            <form class="login-panel p-4 p-md-5" method="post" action="/login" data-login-form>
            <div class="mb-4">
              <div class="security-kicker">100% Passwordless Authentication</div>
              <h2 class="h4 fw-bold mb-1">Session Authorization Gate</h2>
              <p class="muted-copy mb-0">Use your device's biometric scanner to log in securely.</p>
            </div>

            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <div class="mb-3">
              <label class="form-label" for="username">Username</label>
              <input class="form-control form-control-lg" id="username" name="username" autocomplete="username" placeholder="Enter your username" required>
            </div>

            <div class="mb-3">
              <button class="btn btn-bob btn-lg w-100 mb-2" type="button" data-passkey-login>Login with Fingerprint / Passkey</button>
              <div class="form-text text-muted">Secure, phishing-resistant cloud-synced passkeys.</div>
            </div>

            <!-- Hidden telemetry fields always present so contextCollector can populate them -->
            <input type="hidden" name="fingerprint">
            <input type="hidden" name="clientHour">
            <input type="hidden" name="networkScope">
            <input type="hidden" name="loginStartTime">
            <input type="hidden" name="incognito">
            <input type="hidden" name="loginDuration">
            <input type="hidden" name="screenWidth">
            <input type="hidden" name="screenHeight">
            <input type="hidden" name="userAgent">
            <input type="hidden" name="language">
            <input type="hidden" name="timezone">
            <input type="hidden" name="platform">
            <input type="hidden" name="localHour">

            <div class="mt-4 text-center">
              <button class="btn btn-link text-muted small text-decoration-none" type="button" data-bs-toggle="modal" data-bs-target="#qrModal">Login via Cross-Device QR</button>
              <br>
              <button class="btn btn-link text-muted small text-decoration-none" type="button" data-bs-toggle="modal" data-bs-target="#recoveryModal">Lost device? Use Backup Code</button>
              <br>
              <button type="button" class="btn btn-link small text-decoration-none mt-2"
                style="color:rgba(150,150,150,0.4); font-size:.75rem;"
                data-bs-toggle="collapse" data-bs-target="#passwordFallback" aria-expanded="false" aria-controls="passwordFallback">
                Emergency password access
              </button>
            </div>

            <div id="passwordFallback" class="collapse mt-3">
              <div class="mb-3">
                <label class="form-label" for="password">Password</label>
                <input class="form-control form-control-lg" id="password" name="password" type="password" autocomplete="current-password" placeholder="Enter your password">
              </div>

              <div class="mb-3 form-check form-switch">
                <input class="form-check-input" type="checkbox" role="switch" id="mobileFingerprintEnabled" data-mobile-fingerprint-enabled>
                <label class="form-check-label" for="mobileFingerprintEnabled">Enable mobile fingerprint</label>
                <div class="form-text text-muted">On mobile devices, this strengthens the browser fingerprint with touch and hardware signals.</div>
              </div>

              <div class="telemetry-preview mb-4">
                <div><span>Device</span><strong data-preview-device>Collecting</strong></div>
                <div><span>Network</span><strong data-preview-network>Collecting</strong></div>
                <div><span>Browser</span><strong data-preview-mode>Collecting</strong></div>
              </div>

              <button class="btn btn-outline-dark btn-lg w-100" type="submit">Verify Password (Fallback)</button>
            </div>
            </form>


          </section>
        </div>
      </section>

      <section class="container pb-5">
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="info-panel h-100">
              <h2 class="h5 fw-bold">Access Signals</h2>
              <div class="credential-row"><span>Fingerprint</span><strong>Browser-bound</strong></div>
              <div class="credential-row"><span>Network Scope</span><strong>IP-derived</strong></div>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="info-panel h-100">
              <h2 class="h5 fw-bold">Risk Scoring Matrix</h2>
              <div class="matrix-row"><span>Unknown Device</span><strong>+35</strong></div>
              <div class="matrix-row"><span>Unknown Network</span><strong>+30</strong></div>
              <div class="matrix-row"><span>Suspicious Hour</span><strong>+20</strong></div>
              <div class="matrix-row"><span>Incognito + Rapid Login</span><strong>+20</strong></div>
            </div>
          </div>
          <div class="col-lg-4" id="architecture">
            <div class="info-panel h-100">
              <h2 class="h5 fw-bold">Control Flow</h2>
              <div class="flow-line">Credential Verified</div>
              <div class="flow-line">Context Risk Scored</div>
              <div class="flow-line">Challenge or Session</div>
              <div class="flow-line danger">ATO Prevented Before Session</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Recovery Modal -->
      <div class="modal fade" id="recoveryModal" tabindex="-1" aria-labelledby="recoveryModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content">
            <form method="post" action="/recovery-login">
              <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="recoveryModalLabel">Account Recovery</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
              </div>
              <div class="modal-body">
                <p class="text-muted small mb-4">If you have lost access to your device, you can use a backup recovery code to regain access to your account.</p>
                <div class="mb-3">
                  <label class="form-label" for="recoveryUsername">Username</label>
                  <input class="form-control" id="recoveryUsername" name="username" required>
                </div>
                <div class="mb-3">
                  <label class="form-label" for="recoveryCode">Recovery Code</label>
                  <input class="form-control font-monospace" id="recoveryCode" name="recoveryCode" placeholder="XXXX-XXXX-XXXX" required>
                </div>
                <!-- Telemetry fields required for trust pulse logging -->
                <input type="hidden" name="fingerprint">
                <input type="hidden" name="clientHour">
                <input type="hidden" name="networkScope">
                <input type="hidden" name="incognito">
              </div>
              <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-bob">Verify Code</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </main>

    <!-- QR Code Login Modal -->
    <div class="modal fade" id="qrModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-bold">Login via QR Code</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body text-center">
            <p class="text-muted small mb-4">Open the portal on your already logged-in device and scan this QR code to log into this device instantly.</p>
            <div id="qrCodeContainer" class="d-flex justify-content-center mb-3">
              <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
            </div>
            <p id="qrStatusText" class="text-warning fw-bold small">Waiting to be scanned...</p>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/contextCollector.js"></script>
    <script src="/js/passkeyAuth.js"></script>

    <script>
      function togglePasswordFallback() {
        var fallback = document.getElementById('passwordFallback');
        var pwd = document.getElementById('password');
        var isHidden = fallback.classList.contains('d-none');
        fallback.classList.toggle('d-none');
        if (pwd) pwd.required = isHidden;
      }

      let qrPollInterval = null;

      document.getElementById('qrModal').addEventListener('show.bs.modal', async () => {
        const container = document.getElementById('qrCodeContainer');
        const statusText = document.getElementById('qrStatusText');
        container.innerHTML = '<div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>';
        statusText.innerText = 'Generating QR code...';
        statusText.className = 'text-warning fw-bold small';
        if (qrPollInterval) { clearInterval(qrPollInterval); qrPollInterval = null; }

        try {
          const res = await fetch('/api/qr/generate', { method: 'POST' });
          if (!res.ok) throw new Error('Server returned ' + res.status);
          const data = await res.json();
          if (!data.token || !data.qrImage) throw new Error('Invalid response from server');

          // Render QR as plain img — no CDN library needed
          container.innerHTML = '<img src="' + data.qrImage + '" alt="QR Code" width="220" height="220" style="border-radius:8px;">';
          statusText.innerText = 'Waiting to be scanned...';
          statusText.className = 'text-warning fw-bold small';

          const fpData = (typeof window.__trustpulseCollectContext === 'function')
            ? window.__trustpulseCollectContext() : {};
          const queryParams = new URLSearchParams(fpData).toString();

          qrPollInterval = setInterval(async () => {
            try {
              const pollRes = await fetch('/api/qr/status?token=' + encodeURIComponent(data.token) + '&' + queryParams);
              const pollData = await pollRes.json();
              if (pollData.success && pollData.redirect) {
                statusText.innerText = '✅ APPROVED! Redirecting...';
                statusText.className = 'text-success fw-bold small';
                clearInterval(qrPollInterval);
                window.location.href = pollData.redirect;
              } else if (pollData.error) {
                statusText.innerText = pollData.error;
                statusText.className = 'text-danger fw-bold small';
                clearInterval(qrPollInterval);
              }
            } catch (pollErr) {
              console.error('QR poll error:', pollErr);
            }
          }, 2000);

        } catch (err) {
          console.error('QR generation error:', err);
          container.innerHTML = '<p class="text-danger small">Failed to generate QR. Please try again.</p>';
          statusText.innerText = '';
        }
      });

      document.getElementById('qrModal').addEventListener('hidden.bs.modal', () => {
        if (qrPollInterval) { clearInterval(qrPollInterval); qrPollInterval = null; }
      });
    </script>
  </body>
</html>
