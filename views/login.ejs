<!doctype html>
<html lang="en">
  <!-- Security rationale: this page demonstrates that credentials alone do not
       authorize a banking session; context is collected for post-password risk. -->
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>TrustPulse: ATO-Shield</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
  </head>
  <body class="login-shell">
    <nav class="navbar navbar-expand-lg login-nav">
      <div class="container">
        <span class="navbar-brand text-white d-flex align-items-center gap-2 fw-bold">
          <span class="brand-mark">BoB</span>
          TrustPulse: ATO-Shield
        </span>
        <div class="d-flex gap-2">
          <a class="btn btn-sm btn-outline-light" href="#architecture">Architecture</a>
          <button class="btn btn-sm btn-bob" type="button" data-fill-admin>SOC Login</button>
        </div>
      </div>
    </nav>

    <main>
      <section class="container hero-grid py-4 py-lg-5">
        <div class="row align-items-center g-4 g-xl-5">
          <section class="col-lg-7">
            <div class="security-kicker">Bank of Baroda Hackathon 2026</div>
            <h1 class="hero-title mb-3">Detect Account Takeovers before a banking session is created.</h1>
            <p class="hero-copy mb-4">TrustPulse verifies the password, then blocks suspicious credential-stolen logins using device fingerprint, network trust, time anomaly, incognito signals, and login speed.</p>

            <div class="hero-actions mb-4">
              <button class="scenario-button active" type="button" data-scenario="trusted">
                <strong>Trusted Customer</strong>
                <span>Known device, known network, normal behavior</span>
              </button>
              <button class="scenario-button" type="button" data-scenario="attacker">
                <strong>ATO Attacker</strong>
                <span>Correct password from hostile context</span>
              </button>
            </div>

            <div class="row g-3">
              <div class="col-md-4">
                <div class="proof-tile">
                  <span>Session Gate</span>
                  <strong>Pre-Auth</strong>
                </div>
              </div>
              <div class="col-md-4">
                <div class="proof-tile">
                  <span>Risk Threshold</span>
                  <strong>65 / 105</strong>
                </div>
              </div>
              <div class="col-md-4">
                <div class="proof-tile">
                  <span>Decision Model</span>
                  <strong>Explainable</strong>
                </div>
              </div>
            </div>
          </section>

          <section class="col-lg-5">
            <form class="login-panel p-4 p-md-5" method="post" action="/login" data-login-form>
            <div class="mb-4">
              <div class="security-kicker">Adaptive identity assurance</div>
              <h2 class="h4 fw-bold mb-1">Session Authorization Gate</h2>
              <p class="muted-copy mb-0">Password success starts the ATO risk engine, not a session.</p>
            </div>

            <% if (error) { %>
              <div class="alert alert-danger"><%= error %></div>
            <% } %>

            <div class="mb-3">
              <label class="form-label" for="username">Username</label>
              <input class="form-control form-control-lg" id="username" name="username" autocomplete="username" value="trusted" required>
            </div>

            <div class="mb-3">
              <label class="form-label" for="password">Password</label>
              <input class="form-control form-control-lg" id="password" name="password" type="password" autocomplete="current-password" value="bobsecure123" required>
            </div>

            <div class="mb-4">
              <label class="form-label" for="demoMode">Demo Context</label>
              <select class="form-select form-select-lg" id="demoMode" data-demo-mode>
                <option value="trusted">Trusted user: known device and network</option>
                <option value="attacker">ATO attacker: unknown, incognito, rapid login</option>
              </select>
            </div>

            <input type="hidden" name="browserFingerprint">
            <input type="hidden" name="networkSignature">
              <input type="hidden" name="incognito">
              <input type="hidden" name="loginDuration">

              <div class="telemetry-preview mb-4">
                <div><span>Device</span><strong data-preview-device>Collecting</strong></div>
                <div><span>Network</span><strong data-preview-network>Collecting</strong></div>
                <div><span>Mode</span><strong data-preview-mode>Trusted</strong></div>
              </div>

              <button class="btn btn-bob btn-lg w-100" type="submit">Verify Password and Run ATO-Shield</button>
            </form>
          </section>
        </div>
      </section>

      <section class="container pb-5">
        <div class="row g-4">
          <div class="col-lg-4">
            <div class="info-panel h-100">
              <h2 class="h5 fw-bold">Demo Accounts</h2>
              <div class="credential-row"><span>Customer</span><strong><%= demo.trusted %></strong></div>
              <div class="credential-row"><span>SOC Admin</span><strong><%= demo.admin %></strong></div>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="info-panel h-100">
              <h2 class="h5 fw-bold">Risk Scoring Matrix</h2>
              <div class="matrix-row"><span>Unknown Device</span><strong>+35</strong></div>
              <div class="matrix-row"><span>Unknown Network</span><strong>+30</strong></div>
              <div class="matrix-row"><span>Suspicious Hour</span><strong>+20</strong></div>
              <div class="matrix-row"><span>Incognito + Rapid Login</span><strong>+20</strong></div>
            </div>
          </div>
          <div class="col-lg-4" id="architecture">
            <div class="info-panel h-100">
              <h2 class="h5 fw-bold">Control Flow</h2>
              <div class="flow-line">Credential Verified</div>
              <div class="flow-line">Context Risk Scored</div>
              <div class="flow-line">Challenge or Session</div>
              <div class="flow-line danger">ATO Prevented Before Session</div>
            </div>
          </div>
        </div>
      </section>
    </main>
    <script src="/js/contextCollector.js"></script>
  </body>
</html>
