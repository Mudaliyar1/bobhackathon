<!doctype html>
<html lang="en">
  <!-- Security rationale: this portal is intentionally minimal because the demo
       focus is ATO prevention before session creation, not banking workflows. -->
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bank of Baroda Secure Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
  </head>
  <body>
    <nav class="navbar bg-white brand-bar">
      <div class="container">
        <span class="navbar-brand d-flex align-items-center gap-2 fw-bold">
          <span class="brand-mark">BoB</span>
          Secure Banking Portal
        </span>
        <form method="post" action="/logout">
          <button class="btn btn-outline-dark" type="submit">Logout</button>
        </form>
      </div>
    </nav>

    <main class="container py-5">
      <section class="portal-panel p-4 p-md-5">
        <div class="security-kicker">Session authorized</div>
        <h1 class="h2 fw-bold">Welcome, <%= user.username %></h1>
        <p class="muted-copy mb-4">The password was valid and the login context matched the trusted assurance profile, so TrustPulse created the session.</p>
        <div class="row g-3">
          <div class="col-md-4">
            <div class="p-3 border rounded-2">
              <strong>Device Assurance</strong>
              <div class="text-success">Known</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="p-3 border rounded-2">
              <strong>Network Trust</strong>
              <div class="text-success">Known</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="p-3 border rounded-2">
              <strong>Session Gate</strong>
              <div class="text-success">Authorized</div>
            </div>
          </div>
        </div>

        <div class="row g-3 mt-4">
          <div class="col-lg-7">
            <div class="success-flow">
              <div class="flow-line light">Password Verified</div>
              <div class="flow-line light">Known Device Recognized</div>
              <div class="flow-line light">Trusted Network Matched</div>
              <div class="flow-line light safe">Session Created</div>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="operator-note success">
              <strong>ATO-Shield Outcome</strong>
              <span>No adaptive challenge was needed because the environment matched the customer's normal access pattern.</span>
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
