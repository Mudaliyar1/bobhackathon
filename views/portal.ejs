<!doctype html>
<html lang="en">
  <!-- Security rationale: this portal is intentionally minimal because the demo
       focus is ATO prevention before session creation, not banking workflows. -->
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Bank of Baroda Secure Portal</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/css/style.css" rel="stylesheet">
  </head>
  <body data-tp-fingerprint="<%= currentFingerprint || '' %>" data-tp-enrolled="<%= passkeyCount > 0 ? 'true' : 'false' %>">
    <nav class="navbar bg-white brand-bar">
      <div class="container">
        <span class="navbar-brand d-flex align-items-center gap-2 fw-bold">
          <span class="brand-mark">BoB</span>
          Secure Banking Portal
        </span>
        <form method="post" action="/logout">
          <button class="btn btn-outline-dark" type="submit">Logout</button>
        </form>
      </div>
    </nav>

    <main class="container py-5">
      <section class="portal-panel p-4 p-md-5">
        <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
          <div>
            <div class="security-kicker">Session authorized</div>
            <h1 class="h2 fw-bold">Welcome, <%= user.username %></h1>
            <p class="muted-copy mb-0">The password was valid and the login context matched the trusted assurance profile, so TrustPulse created the session.</p>
          </div>
          <span class="secure-badge">Secure Session</span>
        </div>

        <div class="row g-3 mb-4">
          <div class="col-lg-8">
            <div class="operator-note success h-100">
              <strong>Fingerprint Scan Enrollment</strong>
              <span>Scan your fingerprint to register this browser or mobile device with a passkey for future biometric logins.</span>
              <div class="d-flex flex-wrap gap-2 mt-2">
                <button class="btn btn-bob" type="button" data-enroll-passkey>Scan Fingerprint / Enroll</button>
                <span class="align-self-center small text-success" data-fingerprint-status><%= passkeyCount > 0 ? 'Fingerprint enrolled' : 'No fingerprint enrolled yet' %></span>
              </div>
              <small class="text-muted mt-2 d-block">Current fingerprint ID: <span data-current-fingerprint><%= currentFingerprint || 'pending collection' %></span></small>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="p-3 border rounded-2 h-100">
              <strong>Fingerprint Status</strong>
              <div class="mt-2 <%= passkeyCount > 0 ? 'text-success' : 'text-warning' %>" data-fingerprint-enrolled-state><%= passkeyCount > 0 ? 'Enrolled' : 'Not enrolled' %></div>
            </div>
          </div>
        </div>

        <div class="row g-3">
          <div class="col-md-4">
            <div class="p-3 border rounded-2">
              <strong>Device Assurance</strong>
              <div class="text-success">Known</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="p-3 border rounded-2">
              <strong>Network Trust</strong>
              <div class="text-success">Known</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="p-3 border rounded-2">
              <strong>Session Gate</strong>
              <div class="text-success">Authorized</div>
            </div>
          </div>
        </div>

        <div class="row g-3 mt-4">
          <div class="col-12">
            <div class="operator-note bg-light text-dark border h-100">
              <strong>Account Recovery (Backup Codes)</strong>
              <span>Generate 10 secure backup codes. Print them and keep them in a safe place. If you lose your phone, you can use one of these codes to log in securely.</span>
              <div class="mt-2">
                <button class="btn btn-outline-dark btn-sm" type="button" id="generateRecoveryBtn">Generate Backup Codes</button>
              </div>
              <div id="recoveryCodesContainer" class="mt-3 d-none">
                <div class="alert alert-warning small mb-0">
                  <strong>Save these now!</strong> They will only be shown once. Each code can only be used once.
                  <pre id="recoveryCodesList" class="mt-2 mb-0 bg-white p-2 border rounded font-monospace" style="column-count: 2;"></pre>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="row g-3 mt-4">
          <div class="col-lg-4">
            <div class="bank-widget balance-widget">
              <span>Available Balance</span>
              <strong>INR 2,48,900.75</strong>
              <small>Primary savings account</small>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="bank-widget">
              <h2 class="h6 fw-bold mb-3">Recent Transactions</h2>
              <div class="transaction-row"><span>UPI Credit</span><strong>+INR 8,500</strong></div>
              <div class="transaction-row"><span>Card Payment</span><strong>-INR 2,140</strong></div>
              <div class="transaction-row"><span>Salary Credit</span><strong>+INR 82,000</strong></div>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="bank-widget">
              <h2 class="h6 fw-bold mb-3">Transfer Money</h2>
              <input class="form-control mb-2" value="bob-demo-beneficiary" aria-label="Beneficiary" readonly>
              <input class="form-control mb-3" value="5000" aria-label="Amount" readonly>
              <button class="btn btn-outline-dark w-100" type="button">Protected by TrustPulse</button>
            </div>
          </div>
        </div>

        <div class="row g-3 mt-4">
          <div class="col-lg-7">
            <div class="success-flow">
              <div class="flow-line light">Password Verified</div>
              <div class="flow-line light">Known Device Recognized</div>
              <div class="flow-line light">Trusted Network Matched</div>
              <div class="flow-line light safe">Session Created</div>
            </div>
          </div>
          <div class="col-lg-5">
            <div class="operator-note success">
              <strong>ATO-Shield Outcome</strong>
              <span>No adaptive challenge was needed because the environment matched the customer's normal access pattern.</span>
            </div>
            <div class="mt-3">
              <button class="btn btn-outline-primary w-100" data-bs-toggle="modal" data-bs-target="#qrScannerModal">Cross-Device Login</button>
            </div>
          </div>
        </div>
      </section>
    </main>

    <!-- QR Scanner Modal -->
    <div class="modal fade" id="qrScannerModal" tabindex="-1">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-bold">Scan QR to Login</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body text-center">
            <div id="reader" width="100%"></div>
            <p id="scannerStatus" class="text-muted small mt-2">Point your camera at the QR code on your other device.</p>
          </div>
        </div>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
    <script>
      var _p = document.body.dataset;
      window.__trustpulsePortal = {
        currentFingerprint: _p.tpFingerprint || '',
        fingerprintEnrolled: _p.tpEnrolled === 'true'
      };
    </script>
    <script src="/js/portalFingerprint.js"></script>
    <script src="/js/passkeyPortal.js"></script>
    <script src="/js/sessionGuard.js"></script>
    <script>
      document.getElementById('generateRecoveryBtn').addEventListener('click', async () => {
        if (!confirm('Generating new backup codes will invalidate any old ones. Continue?')) return;
        try {
          const res = await fetch('/api/recovery/generate', { method: 'POST' });
          if (!res.ok) {
            const errData = await res.json().catch(() => ({}));
            throw new Error(errData.error || 'Failed to generate codes: ' + res.status);
          }
          const data = await res.json();
          document.getElementById('recoveryCodesList').innerText = data.codes.join('\n');
          document.getElementById('recoveryCodesContainer').classList.remove('d-none');
          document.getElementById('generateRecoveryBtn').disabled = true;
        } catch (err) {
          alert(err.message);
        }
      });

      // --- QR Scanner Logic ---
      let html5QrcodeScanner;

      document.getElementById('qrScannerModal').addEventListener('show.bs.modal', () => {
        document.getElementById('scannerStatus').innerText = 'Point your camera at the QR code on your other device.';
        document.getElementById('scannerStatus').className = 'text-muted small mt-2';
        
        // Initialize the scanner when the modal opens
        html5QrcodeScanner = new Html5QrcodeScanner("reader", { fps: 10, qrbox: {width: 250, height: 250} }, false);
        html5QrcodeScanner.render(onScanSuccess, onScanFailure);
      });

      document.getElementById('qrScannerModal').addEventListener('hidden.bs.modal', () => {
        if (html5QrcodeScanner) {
          html5QrcodeScanner.clear().catch(error => console.error("Failed to clear html5QrcodeScanner. ", error));
        }
      });

      async function onScanSuccess(decodedText, decodedResult) {
        if (html5QrcodeScanner) {
          html5QrcodeScanner.clear();
        }
        document.getElementById('scannerStatus').innerText = 'Approving login...';
        document.getElementById('scannerStatus').className = 'text-warning fw-bold small mt-2';

        try {
          const res = await fetch('/api/qr/approve', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token: decodedText })
          });
          
          if (!res.ok) throw new Error('Failed to approve QR');
          
          document.getElementById('scannerStatus').innerText = 'Success! The other device is now logged in.';
          document.getElementById('scannerStatus').className = 'text-success fw-bold small mt-2';
          
          setTimeout(() => {
            const modal = bootstrap.Modal.getInstance(document.getElementById('qrScannerModal'));
            modal.hide();
          }, 3000);
        } catch (err) {
          document.getElementById('scannerStatus').innerText = 'Error: Invalid or expired QR code.';
          document.getElementById('scannerStatus').className = 'text-danger fw-bold small mt-2';
          console.error(err);
        }
      }

      function onScanFailure(error) {
        // handle scan failure safely
      }
    </script>
  </body>
</html>
